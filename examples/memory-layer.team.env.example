# Shared team hosting (safe to commit once filled with internal URLs).
# Copy to .canon/memory-layer.team.env in each repository.
#
# COMPANY_ID=FMO
# REPOSITORY_ID=github.com/your-org/your-repo
# KNOWLEDGE_API_URL=https://your-knowledge-api.example:8080
# KNOWLEDGE_WORKER_URL=https://your-knowledge-worker.example:8091
# MEMORY_ADAPTER_URL=https://your-memory-adapter.example:8090
# SCOPE_ARTIFACT_BUCKET=your-artifacts-bucket
#
# Optional AWS secret id or name prefix:
# MEMORY_LAYER_AWS_SECRET_ID=your-org/canon/memory-layer
# MEMORY_LAYER_AWS_SECRET_NAME_PREFIX=canon-systems-v2-dev
# AWS_REGION=us-east-1
