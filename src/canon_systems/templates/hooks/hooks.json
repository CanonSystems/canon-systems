{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": "bash .cursor/hooks/memory-preflight.sh",
        "matcher": "UserPromptSubmit",
        "timeout": 20
      },
      {
        "command": "bash .cursor/hooks/vault-sync-preflight.sh",
        "matcher": "UserPromptSubmit",
        "timeout": 20
      },
      {
        "command": "bash .cursor/hooks/task-preflight.sh",
        "matcher": "UserPromptSubmit",
        "timeout": 20
      }
    ],
    "afterAgentResponse": [
      {
        "command": "bash .cursor/hooks/memory-capture.sh",
        "timeout": 20
      }
    ]
  }
}
